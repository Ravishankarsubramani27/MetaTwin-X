# MetaTwin-X Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite:///./data/metatwin.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/metatwindb

# API
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Streamlit
STREAMLIT_PORT=8501

# React Frontend
REACT_APP_API_URL=http://127.0.0.1:8000
REACT_APP_WS_URL=ws://127.0.0.1:8000

# ML Settings
MODEL_DIR=./models
SHAP_MAX_DISPLAY=5

# Simulation
ODE_N_SAMPLES=50          # Monte Carlo samples for uncertainty bands
ODE_DEFAULT_HORIZON=365   # days

# Security (production)
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
